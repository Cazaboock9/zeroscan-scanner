use std.mem

test "openclaw length"
  let openclaw_len i32 23
  expect (== openclaw_len 23)

test "durabletask length"
  let len i32 11
  expect (== len 11)

test "nodeipc length"
  let len i32 8
  expect (== len 8)

test "pytorch length"
  let len i32 17
  expect (== len 17)

test "axios length"
  let len i32 5
  expect (== len 5)

test "dydx length"
  let len i32 13
  expect (== len 13)

test "event-stream length"
  let len i32 12
  expect (== len 12)

test "flatmap-stream length"
  let len i32 14
  expect (== len 14)

test "is-promise length"
  let len i32 10
  expect (== len 10)

test "crypto-js length"
  let len i32 9
  expect (== len 9)

test "systeminformation length"
  let len i32 25
  expect (== len 25)

test "all lengths unique"
  let a i32 23
  let b i32 11
  let c i32 8
  let d i32 17
  let e i32 5
  let f i32 13
  let g i32 12
  let h i32 14
  expect true
